{
  "preview_tabs": {
    "enabled": false,
  },
  "vim_mode": false,
  "tab_size": 4,
  "hard_tabs": false,
  "outline_panel": {
    "dock": "right",
  },
  "collaboration_panel": {
    "dock": "right",
  },
  "git_panel": {
    "dock": "right",
  },
  "project_panel": {
    "dock": "right",
  },
  "restore_on_startup": "launchpad",
  "disable_ai": true,
  "icon_theme": {
    "mode": "dark",
    "light": "Material Icon Theme",
    "dark": "Material Icon Theme",
  },

  "ui_font_family": "JetBrainsMono Nerd Font",
  "ui_font_size": 14,

  "buffer_font_family": "JetBrainsMono Nerd Font",
  "buffer_font_size": 16,
  "buffer_font_features": {
    "liga": true,
    "clig": true,
    "calt": true,
  },

  "theme": {
    "mode": "dark",
    "light": "Catppuccin Latte (Blur)",
    "dark": "Catppuccin Mocha (Blur)",
  },

  "current_line_highlight": "none",
  "selection_highlight": false,

  "format_on_save": "on",

  "soft_wrap": "editor_width",
  "preferred_line_length": 80,
  "show_wrap_guides": true,

  "auto_install_extensions": {
    "html": true,
    "catppuccin-blur": true,
    "toml": true,
    "fish": true,
    "material-icon-theme": true,
    "emmet": true,
  },

  "languages": {
    "HTML": {
      "formatter": "prettier",
      "tab_size": 2,
      "hard_tabs": false,
    },
    "CSS": {
      "formatter": "prettier",
      "tab_size": 2,
      "hard_tabs": false,
    },
    "JavaScript": {
      "formatter": "prettier",
      "tab_size": 2,
      "hard_tabs": false,
    },
    "Python": {
      "language_servers": ["pyright", "ruff"],
      "format_on_save": "on",
      "formatter": {
        "external": {
          "command": "black",
          "arguments": ["-"],
        },
      },
    },
    "C": {
      "language_servers": ["clangd"],
      "format_on_save": "on",
    },
  },

  "prettier": {
    "printWidth": 100,
    "tabWidth": 2,
    "singleQuote": true,
    "bracketSpacing": true,
    "htmlWhitespaceSensitivity": "ignore",
  },
  "terminal": {
    "cursor_shape": "bar",
    "blinking": "on",
  },
  "lsp": {
    "clangd": {
      "binary": {
        "arguments": ["--query-driver=C:\\Users\\Bash\\mingw64\\bin\\gcc.exe"],
      },
    },
  },
}
